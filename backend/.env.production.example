APP_NAME="IPSA"
APP_ENV=production
APP_KEY= # Generate this using php artisan key:generate
APP_DEBUG=false # MUST BE FALSE IN PRODUCTION
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://skl.idnbogor.id

# Frontend URL (Important for CORS and cookies)
FRONTEND_URL=https://skl.idnbogor.id
CORS_ALLOWED_ORIGINS=https://skl.idnbogor.id

LOG_CHANNEL=daily # Daily log rotation is better for production
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error # Only log errors, not info/debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sklidn
DB_USERNAME=root # Change this
DB_PASSWORD= # Change this

SESSION_DRIVER=redis # Switch to redis or database for distributed sessions
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=skl.idnbogor.id
SESSION_SECURE_COOKIE=true # Must be true for HTTPS

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis # Use redis for queues in production

CACHE_STORE=redis # Use redis for better performance
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@sklidn.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sanctum Auth Settings
SANCTUM_STATEFUL_DOMAINS=skl.idnbogor.id,localhost:5173,127.0.0.1:5173

# Security configurations
SCOUT_DRIVER=database
BCRYPT_ROUNDS=12 # Increase from default 10 for better security
